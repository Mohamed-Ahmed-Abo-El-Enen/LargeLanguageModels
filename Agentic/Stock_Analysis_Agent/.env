# ============================================================================
# FINANCIAL AGENT CONFIGURATION
# ============================================================================

# ----------------------------------------------------------------------------
# LLM Provider Configuration
# ----------------------------------------------------------------------------
# Options: anthropic, ollama, openai, google/gemini
LLM_PROVIDER="ollama"

# ----------------------------------------------------------------------------
# Anthropic Configuration (Claude)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY="XXX-XXX-XXX"
ANTHROPIC_MODEL_NAME="claude-haiku-4-5-20251001"

# ----------------------------------------------------------------------------
# Ollama Configuration (Local LLM)
# ----------------------------------------------------------------------------
OLLAMA_MODEL="qwen3:latest"
OLLAMA_BASE_URL="http://localhost:11434"

# ----------------------------------------------------------------------------
# OpenAI Configuration (ChatGPT)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY="XXX-XXX-XXX"
OPENAI_MODEL="gpt-4-turbo-preview"

# ----------------------------------------------------------------------------
# Google Gemini Configuration
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY="XXX-XXX-XXX"
GOOGLE_MODEL="gemini-3-pro-preview"

# ----------------------------------------------------------------------------
# Financial Data APIs
# ----------------------------------------------------------------------------
# Polygon.io - Stock market data
POLYGON_API_KEY="XXX-XXX-XXX"

# Tavily - Web search for news
TAVILY_API_KEY="XXX-XXX-XXX"

# ----------------------------------------------------------------------------
# LangSmith Observability (Optional but Recommended)
# ----------------------------------------------------------------------------
LANGSMITH_API_KEY="XXX-XXX-XXX"
LANGSMITH_PROJECT="XXX-XXX-XXX"
LANGSMITH_TRACING_V2=true

# ----------------------------------------------------------------------------
# ASKNEWS/X API Configuration
# ----------------------------------------------------------------------------
ASKNEWS_CLIENT_ID="XXX-XXX-XXX"
ASKNEWS_CLIENT_SECRET="XXX-XXX-XXX"

# ----------------------------------------------------------------------------
# Twitter/X API Configuration
# ----------------------------------------------------------------------------
TWITTER_API_KEY="XXX-XXX-XXX"
TWITTER_API_SECRET="XXX-XXX-XXX"
TWITTER_BEARER_TOKEN="XXX-XXX-XXX"

# ----------------------------------------------------------------------------
# Reddit API Configuration
# ----------------------------------------------------------------------------
REDDIT_CLIENT_ID="XXX-XXX-XXX"
REDDIT_CLIENT_SECRET="XXX-XXX-XXX"
REDDIT_USER_AGENT="StockTradingAgent/1.0"

# ----------------------------------------------------------------------------
# Social Media Configuration
# ----------------------------------------------------------------------------
# Maximum number of tweets to fetch
MAX_TWEETS=50

# Maximum number of Reddit posts to fetch
MAX_REDDIT_POSTS=50

# Maximum number of Telegram messages to fetch
MAX_TELEGRAM_MESSAGES=50

# Number of days to look back for social media data
SOCIAL_LOOKBACK_DAYS=7

# ----------------------------------------------------------------------------
# Trading Parameters
# ----------------------------------------------------------------------------
# Risk tolerance: low, medium, high
DEFAULT_RISK_TOLERANCE="medium"

# Maximum position size as decimal (0-1, e.g., 0.15 = 15%)
MAX_POSITION_SIZE=0.15

# Minimum confidence threshold (0-100)
MIN_CONFIDENCE_THRESHOLD=60

MODEL_TEMPERATURE=0

